# Copy this file to `.env` or `.env.local` in this `web/` folder and fill values there.
# Do NOT put real API keys in `.env.example` — that file is often committed to git.

# Mapbox — map + geocoding + directions + live traffic ETAs (Directions API driving-traffic profile).
# Use a **public** token. In Mapbox → Tokens → URL restrictions, add every origin you use
# (e.g. https://*.netlify.app/*, your custom domain, and http://192.168.*.*:5173/* for phone-on-Wi‑Fi dev).
VITE_MAPBOX_TOKEN=

# OpenWeather — current weather along route samples (https://openweathermap.org/api)
VITE_OPENWEATHER_API_KEY=

# Optional support contact used by About -> Support and diagnostics email action.
VITE_SUPPORT_EMAIL=
# Optional support site (defaults to /support.html if omitted).
VITE_SUPPORT_URL=

# api.weather.gov User-Agent contact (URL or role email — never your personal email).
# Format: "StormPath/1.0 (+https://your.site/ or support@your.domain)"
VITE_WEATHER_ALERT_USER_AGENT=

# Optional legal links shown in About -> Privacy, safety & data.
VITE_PRIVACY_POLICY_URL=
VITE_TERMS_URL=

# Subscription buttons in About -> Subscription (optional).
# Upgrade: App Store app/product page, Stripe checkout, or your marketing URL — set when billing is live.
# Example App Store: https://apps.apple.com/app/id1234567890
VITE_UPGRADE_URL=
# Manage: Apple account subscriptions page (default in app) or Stripe Customer Portal / your account URL.
# VITE_MANAGE_SUBSCRIPTION_URL=https://apps.apple.com/account/subscriptions

# Plan: "plus" for Plus features on deployed builds (set in Netlify env too). Dev server defaults to Plus without this.
# VITE_PAY_TIER=plus
