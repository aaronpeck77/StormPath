# Public token — safe to embed in the app bundle (still rotate if leaked).
EXPO_PUBLIC_MAPBOX_TOKEN=

# Temporary local entitlement switch for QA/dev builds only.
# Keep false for production unless your entitlement service sets true.
EXPO_PUBLIC_PRO_ENTITLED=false

# RevenueCat public keys/config for in-app purchases.
# Apple key is required for iOS builds.
EXPO_PUBLIC_RC_APPLE_API_KEY=
EXPO_PUBLIC_RC_ENTITLEMENT_ID=pro

# Premium Weather Routing (recommended: your backend; optional: OpenWeather for local dev).
# Backend GET {EXPO_PUBLIC_STORMPATH_API_BASE}/api/v1/weather/current?lat=&lon=
# JSON: { "headline": string, "precipHint"?: number }  (precipHint 0–1 optional)
EXPO_PUBLIC_STORMPATH_API_BASE=
EXPO_PUBLIC_STORMPATH_API_KEY=
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# NWS active alerts (Hazard Guidance) — set a real contact URL or email per api.weather.gov rules.
EXPO_PUBLIC_NWS_USER_AGENT=StormPath-Mobile/1.0 (you@example.com)

# iOS/Android native SDK download (secret token with DOWNLOADS:READ) — paste into app.json
# plugin field RNMapboxMapsDownloadToken, NOT here, unless you use env substitution in CI.
